{
  "name": "client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host=0.0.0.0",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "cleanup": "npm run lint -- --fix && npm run format",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "extract-translations": "ngx-translate-extract --input ./src --output ./src/assets/i18n/en.po --format pot --sort --clean"
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/localize": "~21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@maplibre/ngx-maplibre-gl": "^21.0.2",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@ng-icons/core": "^33.2.2",
    "@ng-icons/font-awesome": "^33.2.2",
    "@ng-icons/heroicons": "^33.2.2",
    "@ng-icons/ionicons": "^33.2.2",
    "@ng-icons/material-icons": "^33.2.2",
    "@ng-icons/material-symbols": "^33.2.2",
    "@ng-icons/octicons": "^33.2.2",
    "@ng-icons/simple-icons": "^33.2.2",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@popperjs/core": "^2.11.8",
    "angular-calendar": "^0.32.2",
    "bootstrap": "^5.3.6",
    "chart.js": "^4.5.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "date-fns": "^4.1.0",
    "maplibre-gl": "^5.24.0",
    "maplibre-theme": "^1.0.0",
    "ngx-translate-lint": "^1.26.5",
    "pofile": "^1.1.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.0.1",
    "@types/jasmine": "~6.0.0",
    "@vendure/ngx-translate-extract": "^10.1.3",
    "angular-eslint": "21.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jasmine-core": "~6.1.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.56.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.58.0"
  },
  "browser": {
    "fs": false
  }
}
